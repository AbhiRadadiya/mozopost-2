# Copy this file to .env.local in the same folder

# URL of the Mozopost API (apps/api). For local dev, leave as-is.
# For production, set this to your deployed API URL, e.g.
# https://mozopost-api.up.railway.app/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# Razorpay public key (safe to expose client-side). Leave blank to use
# wallet recharge in mock mode (matches API mock mode automatically).
NEXT_PUBLIC_RAZORPAY_KEY_ID=
