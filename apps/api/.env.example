# ════════════════════════════════════════════════════════════
# MOZOPOST — ENVIRONMENT CONFIGURATION
# ════════════════════════════════════════════════════════════
# Copy this file to .env in the same folder (apps/api/.env)
# Fill in the values marked [REQUIRED]. Everything else has a
# safe default and can be left as-is for local development.
# ════════════════════════════════════════════════════════════

# ── DATABASE [REQUIRED] ───────────────────────────────────────
# Get a free PostgreSQL DB at https://neon.tech or https://supabase.com
# Or run locally: docker run -p 5432:5432 -e POSTGRES_PASSWORD=postgres postgres:16
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/mozopost

#Prod
DATABASE_URL=postgres://mozo_admin:Mozopost%400076@127.0.0.1:5432/mozopost

# ── REDIS (for background jobs - AWB booking, label generation) ─
# Free Redis at https://upstash.com, or run locally:
# docker run -p 6379:6379 redis:7
REDIS_URL=redis://localhost:6379

# ── AUTH [REQUIRED] ────────────────────────────────────────────
# Generate one with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=30

# ── SERVER ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000

# ── PAYMENT GATEWAY (wallet recharge) [OPTIONAL] ────────────────
# Get keys at https://dashboard.razorpay.com/app/keys
# Leave blank to run wallet recharge in "demo/mock" mode
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── SMS PROVIDER [OPTIONAL] ──────────────────────────────────────
# Get keys at https://msg91.com — leave blank to log OTPs to console instead
MSG91_AUTH_KEY=
MSG91_SENDER_ID=MOZPST
MSG91_OTP_TEMPLATE_ID=

# ── EMAIL PROVIDER [OPTIONAL] ────────────────────────────────────
# Get a key at https://sendgrid.com — leave blank to log emails to console
SENDGRID_API_KEY=
EMAIL_FROM=noreply@mozopost.in

# ── COURIER API KEYS [OPTIONAL — add as you onboard each courier] ─
# Until filled in, that courier's adapter runs in MOCK mode:
# it returns a realistic fake AWB and tracking events so you can
# test the full order flow end-to-end before going live with carriers.

# Delhivery — https://www.delhivery.com/business/api
DELHIVERY_API_KEY=
DELHIVERY_BASE_URL=https://track.delhivery.com

# Bluedart — https://www.bluedart.com/web-services
BLUEDART_LOGIN_ID=
BLUEDART_LICENSE_KEY=
BLUEDART_API_TYPE=

# DTDC — https://www.dtdc.in/api-integration
DTDC_API_KEY=
DTDC_CUSTOMER_CODE=

# Ekart — https://www.ekartlogistics.com/business
EKART_API_KEY=
EKART_MERCHANT_ID=

# Shadowfax — https://shadowfax.in/business
SHADOWFAX_API_KEY=

# XpressBees — https://www.xpressbees.com/business
XPRESSBEES_EMAIL=
XPRESSBEES_PASSWORD=

# EcomExpress — https://ecomexpress.in
ECOMEXPRESS_USERNAME=
ECOMEXPRESS_PASSWORD=

# Amazon Shipping — https://logistics.amazon.in
AMAZON_SHIPPING_CLIENT_ID=
AMAZON_SHIPPING_CLIENT_SECRET=

# India Post, Gati, DLH — typically onboarded via aggregator contract;
# leave blank and use mock mode until you have direct API access.
INDIA_POST_API_KEY=
GATI_API_KEY=
DLH_API_KEY=

# ── ENCRYPTION KEY for courier credentials at rest [REQUIRED] ────
# Generate with: openssl rand -hex 32
CREDENTIALS_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS
